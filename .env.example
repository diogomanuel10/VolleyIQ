# ── Server ──────────────────────────────────────────
PORT=3000
DATABASE_URL=./volleyiq.db
NODE_ENV=development

# Set to "true" to skip Firebase token verification and inject a mock user.
# Use only in local dev. In prod, leave unset and provide a service account.
DEV_AUTH_BYPASS=true
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── AI (Anthropic Claude) ───────────────────────────
ANTHROPIC_API_KEY=
# "true" returns deterministic fake patterns/recommendations.
AI_MOCK=true

# ── Client (Vite) ───────────────────────────────────
VITE_USE_DEV_AUTH=true
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
